// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Evento {
  id           Int    @id @default(autoincrement())
  local        String
  horario      String
  diaDaSemana  String @map("dia_da_semana") // No JS: diaDaSemana | No Postgres: dia_da_semana
  blusa        String
  bermuda      String
  cache        Float?

  @@map("eventos") // No JS: prisma.evento | No Postgres: tabela "eventos"
}